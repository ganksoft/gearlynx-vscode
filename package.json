{
  "name": "gearlynxdebugger",
  "displayName": "Gearlynx Debugger",
  "description": "Source-level debugger for Atari Lynx games using the Gearlynx emulator",
  "version": "0.1.0",
  "publisher": "Ganksoft",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BrianPeek/gearlynx-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/BrianPeek/gearlynx-vscode/issues"
  },
  "homepage": "https://github.com/BrianPeek/gearlynx-vscode#readme",
  "keywords": [
    "atari",
    "lynx",
    "debugger",
    "cc65",
    "6502",
    "gearlynx",
    "emulator"
  ],
  "engines": {
    "vscode": "^1.87.0"
  },
  "main": "./out/extension.js",
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:lynx"
  ],
  "contributes": {
    "commands": [
      {
        "command": "lynxDebug.selectOverlay",
        "title": "Select Active Overlay",
        "category": "Lynx Debug"
      },
      {
        "command": "lynxDebug.showScreen",
        "title": "Show Screen Viewer",
        "category": "Lynx Debug"
      },
      {
        "command": "lynxDebug.showMemoryMap",
        "title": "Show Memory Map",
        "category": "Lynx Debug"
      },
      {
        "command": "lynxDebug.startTraceLog",
        "title": "Start Trace Logger",
        "category": "Lynx Debug"
      },
      {
        "command": "lynxDebug.stopTraceLog",
        "title": "Stop Trace Logger",
        "category": "Lynx Debug"
      },
      {
        "command": "lynxDebug.showTraceLog",
        "title": "Show Trace Log",
        "category": "Lynx Debug"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "lynxDebugPanel",
          "title": "Lynx",
          "icon": "$(game)"
        }
      ]
    },
    "views": {
      "lynxDebugPanel": [
        {
          "type": "webview",
          "id": "lynxDebug.screenView",
          "name": "Screen",
          "when": "debugType == 'lynx'"
        }
      ]
    },
    "breakpoints": [
      { "language": "c" },
      { "language": "cpp" },
      { "language": "asm" }
    ],
    "debuggers": [
      {
        "type": "lynx",
        "label": "Lynx Debug",
        "languages": ["c", "cpp", "asm"],
        "configurationAttributes": {
          "launch": {
            "required": ["rom"],
            "properties": {
              "rom": {
                "type": "string",
                "description": "Path to ROM file (.lnx, .lyx, .o)"
              },
              "debugFile": {
                "type": "string",
                "description": "Path to debug info file (.dbg or .sym). Auto-detected if omitted."
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause execution at entry point.",
                "default": false
              },
              "port": {
                "type": "number",
                "description": "Debug monitor port on Gearlynx.",
                "default": 6502
              },
              "gearlynxPath": {
                "type": "string",
                "description": "Path to Gearlynx executable. Uses setting if omitted."
              },
              "sourceRoots": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Additional directories to search for source files referenced in debug info.",
                "default": []
              },
              "headless": {
                "type": "boolean",
                "description": "Run Gearlynx without GUI window. Use the Screen Viewer in VSCode instead.",
                "default": false
              },
              "traceSteps": {
                "type": "boolean",
                "description": "Log each micro-step decision to the Debug Console for diagnosing source-line stepping.",
                "default": false
              }
            }
          },
          "attach": {
            "properties": {
              "debugFile": {
                "type": "string",
                "description": "Path to debug info file (.dbg or .sym)."
              },
              "hostname": {
                "type": "string",
                "description": "Host running Gearlynx.",
                "default": "localhost"
              },
              "port": {
                "type": "number",
                "description": "Debug monitor port.",
                "default": 6502
              },
              "sourceRoots": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Additional directories to search for source files.",
                "default": []
              },
              "traceSteps": {
                "type": "boolean",
                "description": "Log each micro-step decision to the Debug Console for diagnosing source-line stepping.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "lynx",
            "request": "launch",
            "name": "Launch Lynx Game",
            "rom": "${workspaceFolder}/game.lnx",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "Lynx Debug: Launch",
            "description": "Launch a Lynx game in Gearlynx with debugging",
            "body": {
              "type": "lynx",
              "request": "launch",
              "name": "Launch Lynx",
              "rom": "^\"\\${workspaceFolder}/${1:game.lnx}\"",
              "stopOnEntry": true
            }
          },
          {
            "label": "Lynx Debug: Attach",
            "description": "Attach to a running Gearlynx instance",
            "body": {
              "type": "lynx",
              "request": "attach",
              "name": "Attach to Gearlynx",
              "port": 6502
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Lynx Debug",
      "properties": {
        "lynxDebug.gearlynxPath": {
          "type": "string",
          "default": "",
          "description": "Path to Gearlynx executable"
        },
        "lynxDebug.defaultPort": {
          "type": "number",
          "default": 6502,
          "description": "Default debug monitor port"
        },
        "lynxDebug.autoOpenScreen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the Screen Viewer when a debug session starts"
        },
        "lynxDebug.keymap.up": {
          "type": "string",
          "default": "ArrowUp",
          "description": "Key for D-pad Up"
        },
        "lynxDebug.keymap.down": {
          "type": "string",
          "default": "ArrowDown",
          "description": "Key for D-pad Down"
        },
        "lynxDebug.keymap.left": {
          "type": "string",
          "default": "ArrowLeft",
          "description": "Key for D-pad Left"
        },
        "lynxDebug.keymap.right": {
          "type": "string",
          "default": "ArrowRight",
          "description": "Key for D-pad Right"
        },
        "lynxDebug.keymap.a": {
          "type": "string",
          "default": "z",
          "description": "Key for A button"
        },
        "lynxDebug.keymap.b": {
          "type": "string",
          "default": "x",
          "description": "Key for B button"
        },
        "lynxDebug.keymap.option1": {
          "type": "string",
          "default": "1",
          "description": "Key for Option 1"
        },
        "lynxDebug.keymap.option2": {
          "type": "string",
          "default": "2",
          "description": "Key for Option 2"
        },
        "lynxDebug.keymap.pause": {
          "type": "string",
          "default": "3",
          "description": "Key for Pause"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.87.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
